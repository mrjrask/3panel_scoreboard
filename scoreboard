#!/usr/bin/env bash
set -euo pipefail

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SCRIPT_SOURCE" ]; do
  SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" >/dev/null 2>&1 && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
REPO_DIR="$(cd -P "$(dirname "$SCRIPT_SOURCE")" >/dev/null 2>&1 && pwd)"
if [[ -n "${VENV_DIR:-}" ]]; then
  VENV_EXPLICIT=1
else
  VENV_EXPLICIT=0
  VENV_DIR="$REPO_DIR/.venv"
fi
PYTHON_BIN="${PYTHON_BIN:-python}"
BACKEND="${SCOREBOARD_BACKEND:-rgbmatrix}"
PRINT_COMMAND=0
USE_SUDO=1
PRESET="three-panel"
EXTRA_ARGS=()
PRESET_ARGS=()

usage() {
  cat <<USAGE
Usage: $(basename "$0") [preset] [options passed to main.py]

Short launcher for the 3-panel baseball scoreboard. The launcher always adds:
  --backend <backend> --led-no-hardware-pulse

Presets:
  3, basic, three, three-panel       Three horizontal panels (default)
  3v, three-vertical, rotated-3      Three rotated vertical panels (clockwise)
  3v-ccw, rotated-3-ccw             Three rotated vertical panels (counter-clockwise)
  2, two, two-panel                  Two horizontal panels on ports 1 and 2
  2v, two-vertical, rotated-2        Two rotated vertical panels (clockwise)
  2v-ccw, rotated-2-ccw             Two rotated vertical panels (counter-clockwise)

Launcher options:
  --backend BACKEND                  Driver backend: rgbmatrix (default), piomatter, or auto
  --repo-dir DIR                     Repository directory (default: launcher location)
  --venv DIR                         Virtual environment directory (default: REPO_DIR/.venv)
  --python BIN                       Python executable name/path inside the sudo environment
  --no-sudo                          Run directly instead of through sudo -E
  --print-command                    Print the command instead of running it
  -h, --help                         Show this help
  --                                 Stop launcher parsing; pass remaining args to main.py

Examples:
  $(basename "$0")                  # three-panel horizontal Pi 4/rgbmatrix
  $(basename "$0") 3v               # three-panel rotated clockwise
  $(basename "$0") 2                # two-panel horizontal
  $(basename "$0") 2v               # two-panel rotated clockwise
  $(basename "$0") 2v-ccw --port 80 # two-panel rotated counter-clockwise, web UI on port 80
USAGE
}

quote_command() {
  printf '%q ' "$@"
  printf '\n'
}

ensure_runtime_permissions() {
  local permission_errors=0

  # Keep the checked-out repository path traversable and the bundled bitmap
  # fonts readable for whichever user ultimately runs main.py (for example,
  # sudo/root, systemd, or a dedicated service account). Git does not preserve
  # directory modes or non-executable read bits, so repair them at launch time.
  if [[ -d "$REPO_DIR" ]]; then
    chmod a+rx "$REPO_DIR" || permission_errors=1
  fi

  if [[ -d "$REPO_DIR/fonts" ]]; then
    chmod a+rx "$REPO_DIR/fonts" || permission_errors=1
    find "$REPO_DIR/fonts" -maxdepth 1 -type f -name '*.bdf' -exec chmod a+r {} + || permission_errors=1
  fi

  if [[ -e "$REPO_DIR/scoreboard" ]]; then
    chmod a+rx "$REPO_DIR/scoreboard" || permission_errors=1
  fi

  if ((permission_errors)); then
    echo "scoreboard launcher: warning: unable to repair one or more repository/font permissions under $REPO_DIR" >&2
  fi
}

while (($#)); do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --print-command)
      PRINT_COMMAND=1
      shift
      ;;
    --no-sudo)
      USE_SUDO=0
      shift
      ;;
    --backend)
      if (($# < 2)); then
        echo "error: --backend requires a value" >&2
        exit 2
      fi
      BACKEND="$2"
      shift 2
      ;;
    --backend=*)
      BACKEND="${1#--backend=}"
      shift
      ;;
    --repo-dir)
      if (($# < 2)); then
        echo "error: --repo-dir requires a value" >&2
        exit 2
      fi
      REPO_DIR="$2"
      if ((VENV_EXPLICIT == 0)); then
        VENV_DIR="$REPO_DIR/.venv"
      fi
      shift 2
      ;;
    --repo-dir=*)
      REPO_DIR="${1#--repo-dir=}"
      if ((VENV_EXPLICIT == 0)); then
        VENV_DIR="$REPO_DIR/.venv"
      fi
      shift
      ;;
    --venv)
      if (($# < 2)); then
        echo "error: --venv requires a value" >&2
        exit 2
      fi
      VENV_DIR="$2"
      VENV_EXPLICIT=1
      shift 2
      ;;
    --venv=*)
      VENV_DIR="${1#--venv=}"
      VENV_EXPLICIT=1
      shift
      ;;
    --python)
      if (($# < 2)); then
        echo "error: --python requires a value" >&2
        exit 2
      fi
      PYTHON_BIN="$2"
      shift 2
      ;;
    --python=*)
      PYTHON_BIN="${1#--python=}"
      shift
      ;;
    --)
      shift
      EXTRA_ARGS+=("$@")
      break
      ;;
    3|basic|three|three-panel)
      PRESET="three-panel"
      shift
      ;;
    3v|three-vertical|rotated-3)
      PRESET="three-panel-vertical"
      shift
      ;;
    3v-ccw|three-vertical-ccw|rotated-3-ccw)
      PRESET="three-panel-vertical-ccw"
      shift
      ;;
    2|two|two-panel)
      PRESET="two-panel"
      shift
      ;;
    2v|two-vertical|rotated-2)
      PRESET="two-panel-vertical"
      shift
      ;;
    2v-ccw|two-vertical-ccw|rotated-2-ccw)
      PRESET="two-panel-vertical-ccw"
      shift
      ;;
    *)
      # The first non-launcher argument starts the main.py argument list. Stop
      # parsing launcher presets here so option values like `--brightness 3` or
      # `--chain-across 2` are preserved instead of being mistaken for presets.
      EXTRA_ARGS+=("$@")
      break
      ;;
  esac
done

case "$PRESET" in
  three-panel)
    PRESET_ARGS=()
    ;;
  three-panel-vertical)
    PRESET_ARGS=(--vertical-screen)
    ;;
  three-panel-vertical-ccw)
    PRESET_ARGS=(--screen-orientation vertical-ccw)
    ;;
  two-panel)
    PRESET_ARGS=(--two-panel)
    ;;
  two-panel-vertical)
    PRESET_ARGS=(--two-panel --vertical-screen)
    ;;
  two-panel-vertical-ccw)
    PRESET_ARGS=(--two-panel --screen-orientation vertical-ccw)
    ;;
esac

RUN_ENV=(env "PATH=$VENV_DIR/bin:$PATH")
APP_CMD=("$PYTHON_BIN" "$REPO_DIR/main.py" --backend "$BACKEND" --led-no-hardware-pulse "${PRESET_ARGS[@]}" "${EXTRA_ARGS[@]}")

if ((USE_SUDO)); then
  COMMAND=(sudo -E "${RUN_ENV[@]}" "${APP_CMD[@]}")
else
  COMMAND=("${RUN_ENV[@]}" "${APP_CMD[@]}")
fi

ensure_runtime_permissions

if ((PRINT_COMMAND)); then
  quote_command "${COMMAND[@]}"
  exit 0
fi

CHILD_PID=""
STOPPING=0

stop_child() {
  local signal="${1:-TERM}"
  local child="$CHILD_PID"

  if [[ -z "$child" ]] || ! kill -0 "$child" 2>/dev/null; then
    return
  fi

  if ((STOPPING == 0)); then
    STOPPING=1
    echo "scoreboard launcher: received $signal; stopping child process $child..." >&2
  fi

  # sudo can leave the Python process running as a child for a short window. Walk
  # the direct-descendant tree before signaling the parent so Ctrl+C reliably
  # tears down the whole launched app even when native LED-matrix initialization
  # is stuck.
  local descendants=()
  if command -v pgrep >/dev/null 2>&1; then
    local queue=("$child")
    local parent
    local kids
    while ((${#queue[@]})); do
      parent="${queue[0]}"
      queue=("${queue[@]:1}")
      kids=()
      while IFS= read -r kid; do
        [[ -n "$kid" ]] && kids+=("$kid")
      done < <(pgrep -P "$parent" 2>/dev/null || true)
      if ((${#kids[@]})); then
        descendants+=("${kids[@]}")
        queue+=("${kids[@]}")
      fi
    done
  fi

  if ((${#descendants[@]})); then
    kill -"$signal" "${descendants[@]}" 2>/dev/null || true
  fi
  kill -"$signal" "$child" 2>/dev/null || true
}

force_stop_child() {
  stop_child "TERM"
  sleep 2
  if [[ -n "$CHILD_PID" ]] && kill -0 "$CHILD_PID" 2>/dev/null; then
    echo "scoreboard launcher: child did not exit after TERM; sending KILL..." >&2
    stop_child "KILL"
  fi
}

trap 'stop_child INT; exit 130' INT
trap 'force_stop_child; exit 143' TERM
trap 'if ((STOPPING)); then force_stop_child; fi' EXIT

"${COMMAND[@]}" &
CHILD_PID=$!
set +e
wait "$CHILD_PID"
status=$?
set -e
CHILD_PID=""
exit "$status"
